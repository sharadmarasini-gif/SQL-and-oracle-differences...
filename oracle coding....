-- ============================================
-- 7. INNER JOIN (Employee + Department)
-- ============================================

SELECT 
    e.FNAME AS FirstName,
    e.LNAME AS LastName,
    e.SALARY AS Salary,
    d.DNAME AS DepartmentName
FROM EMPLOYEE e
JOIN DEPARTMENT d
ON e.DNO = d.DNUMBER;

